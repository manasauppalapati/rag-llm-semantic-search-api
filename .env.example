# ── OpenAI ──────────────────────────────────────────────────
# REQUIRED — your OpenAI API key
OPENAI_API_KEY=your-openai-api-key-here

# Embedding model — do not change unless you know the implications
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Completion model for RAG answers and query rewriting
OPENAI_COMPLETION_MODEL=gpt-4o-mini

# Max tokens per completion response
OPENAI_MAX_TOKENS=1000

# ── Redis ────────────────────────────────────────────────────
# Local: redis://localhost:6379 | Docker Compose: redis://redis:6379
REDIS_URL=redis://localhost:6379

# TTL in seconds for cached answers (1 hour)
REDIS_TTL_ANSWER=3600

# TTL in seconds for session history (1 hour)
REDIS_TTL_SESSION=3600

# TTL in seconds for ingestion job state (24 hours)
REDIS_TTL_JOB=86400

# TTL in seconds for rate limit buckets (2x window for auto-cleanup)
REDIS_TTL_RATE_BUCKET=120

# ── FAISS ────────────────────────────────────────────────────
# Directory for persisted FAISS indexes
# In Docker this maps to the bind-mount volume
FAISS_INDEX_DIR=./faiss_indexes

# ── Chunking ─────────────────────────────────────────────────
# Target chunk size in tokens
CHUNK_SIZE_TOKENS=512

# Token overlap between adjacent chunks
CHUNK_OVERLAP_TOKENS=50

# ── Retrieval ────────────────────────────────────────────────
# Default number of chunks to retrieve per query
TOP_K_DEFAULT=5

# Hard ceiling on top_k per request
TOP_K_MAX=10

# FAISS fetch size when re-ranking is enabled
TOP_K_RERANK_FETCH=10

# Minimum cosine similarity to include a chunk (0.0 < x < 1.0)
SIMILARITY_THRESHOLD=0.75

# ── Re-ranking ───────────────────────────────────────────────
# Cross-encoder model for two-stage retrieval
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Enable re-ranking globally (overridden per-request)
RERANK_ENABLED=false

# ── Rate Limiting ────────────────────────────────────────────
# Maximum requests per window per API key
RATE_LIMIT_REQUESTS=100

# Rate limit window in seconds
RATE_LIMIT_WINDOW_SECONDS=60

# ── Auth ─────────────────────────────────────────────────────
# REQUIRED — secret for /admin/keys endpoints
# Use a strong random value: openssl rand -hex 32
ADMIN_SECRET=your-admin-secret-here

# ── Application ──────────────────────────────────────────────
APP_VERSION=1.1.0

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Environment: development | staging | production
APP_ENV=development
